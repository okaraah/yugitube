DUELINGBOOK_USERNAME=
DUELINGBOOK_PASSWORD=

# Supervisor defaults to billyburger1..billyburger5 with shared password billy123.
# Override with a comma-separated list if needed.
DUELINGBOOK_WATCHER_ACCOUNTS=billyburger1,billyburger2,billyburger3,billyburger4,billyburger5
DUELINGBOOK_WATCHER_PASSWORD=billy123

# Qualifying duel filter
SCRAPER_DUEL_TYPE=m
SCRAPER_DUEL_FORMAT=ar
SCRAPER_DUEL_RULES=TCG
SCRAPER_MIN_RATING=300

# Admin panel auth for the replay site
YUGITUBE_ADMIN_PASSWORD=change-me
# Optional; defaults to YUGITUBE_ADMIN_PASSWORD if omitted
YUGITUBE_ADMIN_SESSION_SECRET=
